<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- 任务标签 -->
    <key>Label</key>
    <string>com.kaipanla.sentiment.monitor</string>
    
    <!-- 要执行的脚本 -->
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/macclaw/.openclaw/workspace/scripts/sentiment_launchd.sh</string>
    </array>
    
    <!-- 工作目录 -->
    <key>WorkingDirectory</key>
    <string>/Users/macclaw/.openclaw/workspace</string>
    
    <!-- 每 5 分钟运行一次（300 秒） -->
    <key>StartInterval</key>
    <integer>300</integer>
    
    <!-- 如果错过执行时间，立即补跑 -->
    <key>RunAtLoad</key>
    <false/>
    
    <!-- 标准输出和错误日志 -->
    <key>StandardOutPath</key>
    <string>/tmp/kaipanla/launchd_stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/kaipanla/launchd_stderr.log</string>
    
    <!-- 环境变量 -->
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>
</dict>
</plist>
