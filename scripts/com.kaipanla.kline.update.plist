<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.kaipanla.kline.update</string>
    
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/macclaw/.openclaw/workspace/scripts/update_kline_data.sh</string>
    </array>
    
    <key>WorkingDirectory</key>
    <string>/Users/macclaw/.openclaw/workspace</string>
    
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>15</integer>
        <key>Minute</key>
        <integer>5</integer>
    </dict>
    
    <key>StandardOutPath</key>
    <string>/tmp/kaipanla/kline_update_stdout.log</string>
    
    <key>StandardErrorPath</key>
    <string>/tmp/kaipanla/kline_update_stderr.log</string>
    
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
        <key>GIT_ASKPASS</key>
        <string>echo</string>
    </dict>
</dict>
</plist>
